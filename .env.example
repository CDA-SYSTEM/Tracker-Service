# ============================================================
# Tracker Service - Variables de Entorno
# Copia este archivo como .env y ajusta los valores
# ============================================================

# --- RabbitMQ ---
# Opción 1: URI completa (sobreescribe HOST/PORT/USER/PASSWORD)
RABBITMQ_URI=amqp://guest:guest@100.94.204.56:5672

# Opción 2: Valores individuales (usados si RABBITMQ_URI está vacío)
RABBITMQ_HOST=100.94.204.56
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Cola donde este servicio escucha los eventos
RABBITMQ_QUEUE=tracker_service.queue

# --- Neo4j ---
NEO4J_URI=bolt://100.94.204.56:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- Flask ---
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# --- API Key (middleware de seguridad) ---
# Si está vacío, el middleware se desactiva (sin autenticación).
# Si tiene un valor, todas las rutas /api/* exigen header X-API-Key.
API_KEY=
